# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=verify-full

# Backup Database URL (for Neon, use the direct connection string without pooler)
# BACKUP_DATABASE_URL=postgresql://username:password@direct-host:port/database?sslmode=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Backup Configuration
BACKUP_PATH=path/to/backup/directory

# PostgreSQL Bin Path (for pg_dump)
POSTGRES_BIN_PATH=C:\Program Files\PostgreSQL\18\bin

# Email Configuration (for password reset, notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@example.com

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Rate Limiting (if using Upstash Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
